generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String
  crest     String   @default("")
  league    String
  createdAt DateTime @default(now())

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id         String   @id @default(cuid())
  homeTeamId String
  awayTeamId String
  league     String
  kickoff    DateTime
  status     String   @default("scheduled") // scheduled | live | finished
  homeScore  Int?
  awayScore  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions Prediction[]
  analyses    Analysis[]
  odds        Odds[]
  bets        Bet[]
}

model Prediction {
  id             String   @id @default(cuid())
  matchId        String
  homeWin        Float
  draw           Float
  awayWin        Float
  over25         Float
  under25        Float
  btts           Float
  expectedHome   Float
  expectedAway   Float
  modelVersion   String   @default("poisson-v1")
  createdAt      DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

model Odds {
  id        String   @id @default(cuid())
  matchId   String
  homeWin   Float
  draw      Float
  awayWin   Float
  over25    Float?
  under25   Float?
  btts      Float?
  bttNo     Float?
  source    String
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

model Analysis {
  id                 String   @id @default(cuid())
  matchId            String
  summary            String
  reasoning          String[] // array of reasoning points
  riskFactors        String[]
  valueAssessment    String
  recommendation     String   // bet | small-stake | no-bet | avoid
  recommendationText String
  confidence         String   // high | medium | low
  contradictions     String[]
  marketBehaviour    String?
  createdAt          DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  bankroll  Float    @default(500)
  currency  String   @default("GBP")
  createdAt DateTime @default(now())

  bets Bet[]
}

model Bet {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  market    String
  stake     Float
  odds      Float
  result    String?  // won | lost | void
  profit    Float?
  placedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])
}
